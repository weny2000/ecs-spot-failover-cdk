{
  "name": "ecs-fargate-spot-failover-cdk",
  "version": "1.0.0",
  "description": "ECS Fargate Spot instance automatic failover solution with one-click deployment",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "lib/**/*.js",
    "lib/**/*.d.ts",
    "src/lambda/**/*",
    "src/step-functions/**/*"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest test/unit",
    "test:integration": "jest test/integration --testTimeout=60000",
    "cdk": "cdk",
    "deploy": "npm run build && cdk deploy",
    "deploy:minimal": "npm run build && cdk deploy -c createSampleApp=false",
    "deploy:multi": "npm run build && node scripts/deploy-multi-region.js",
    "destroy": "cdk destroy",
    "synth": "npm run build && cdk synth",
    "diff": "npm run build && cdk diff",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "lint:security": "eslint . --ext .ts --rule 'no-eval: error' --rule 'no-implied-eval: error'",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"scripts/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\" \"scripts/**/*.js\"",
    "clean": "rm -rf dist cdk.out coverage",
    "predeploy": "npm run build"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.119",
    "@types/jest": "^29.5.5",
    "@types/node": "^20.6.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.2.2"
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch": "^3.450.0",
    "@aws-sdk/client-dynamodb": "^3.450.0",
    "@aws-sdk/client-ecs": "^3.450.0",
    "@aws-sdk/client-lambda": "^3.450.0",
    "@aws-sdk/client-sns": "^3.450.0",
    "@aws-sdk/client-sfn": "^3.450.0",
    "@aws-sdk/client-route-53": "^3.450.0",
    "@aws-sdk/client-xray": "^3.450.0",
    "@aws-sdk/lib-dynamodb": "^3.450.0",
    "aws-cdk-lib": "^2.100.0",
    "aws-xray-sdk-core": "^3.5.3",
    "constructs": "^10.3.0",
    "source-map-support": "^0.5.21"
  },
  "keywords": [
    "aws",
    "cdk",
    "ecs",
    "fargate",
    "spot",
    "failover",
    "serverless",
    "cost-optimization",
    "high-availability"
  ],
  "author": "weny2000 <weny2000@example.com>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/weny2000/ecs-spot-failover-cdk.git"
  },
  "bugs": {
    "url": "https://github.com/weny2000/ecs-spot-failover-cdk/issues"
  },
  "homepage": "https://github.com/weny2000/ecs-spot-failover-cdk#readme"
}
