実装コード
1. Lambda：Mount Targetの自動作成
pythonimport boto3
import os
import time

efs = boto3.client('efs')
ssm = boto3.client('ssm')
ecs = boto3.client('ecs')

FILE_SYSTEM_ID = os.environ['EFS_FILE_SYSTEM_ID']
THRESHOLD = int(os.environ.get('FILE_COUNT_THRESHOLD', '100000'))

def lambda_handler(event, context):
    """
    ファイル数を監視し、Mount Targetを自動スケール
    """
    # 1. EFSをマウントしてファイル数を統計
    file_count = count_files_in_efs('/mnt/efs/data/analysis')
    print(f"現在のファイル数: {file_count}")
    
    # 2. 閾値チェック
    if file_count <= THRESHOLD:
        print(f"閾値({THRESHOLD})未満、操作不要")
        return {'statusCode': 200}
    
    print(f"⚠️ 閾値超過: {file_count} > {THRESHOLD}")
    
    # 3. 既存のMount Targetを取得
    existing_mts = get_mount_targets(FILE_SYSTEM_ID)
    print(f"既存のMount Target: {len(existing_mts)}個")
    
    # 4. 利用可能なサブネットを検索
    available_subnet = find_available_subnet(existing_mts)
    
    if not available_subnet:
        print("⚠️ 利用可能なサブネットなし - すべてのAZをカバー済み")
        return {'statusCode': 200}
    
    # 5. 新規Mount Target作成
    print(f"Mount Target作成: サブネット {available_subnet['SubnetId']}")
    new_mt = create_mount_target(
        FILE_SYSTEM_ID,
        available_subnet['SubnetId']
    )
    
    # 6. SSM Parameter Store更新
    all_mts = existing_mts + [new_mt]
    update_ssm_parameter('/efs-mount-autoscaling/mount-targets', all_mts)
    
    # 7. ECSサービス強制再デプロイ（新設定を反映）
    trigger_ecs_deployment(
        os.environ['ECS_CLUSTER_NAME'],
        os.environ['ECS_SERVICE_NAME']
    )
    
    print(f"✅ スケール完了: {len(existing_mts)} → {len(all_mts)}個のMount Target")
    
    return {
        'statusCode': 200,
        'new_mount_target': new_mt,
        'total': len(all_mts)
    }

def count_files_in_efs(directory):
    """
    EFSのファイル数を統計
    注意：Lambdaの /mnt をEFSマウントポイントとして設定する必要あり
    """
    count = 0
    for root, dirs, files in os.walk(directory):
        count += len(files)
    return count

def get_mount_targets(fs_id):
    """
    既存のMount Targetを取得
    """
    response = efs.describe_mount_targets(FileSystemId=fs_id)
    
    return [{
        'mount_target_id': mt['MountTargetId'],
        'ip_address': mt['IpAddress'],
        'availability_zone': mt['AvailabilityZoneName'],
        'subnet_id': mt['SubnetId']
    } for mt in response['MountTargets']]

def find_available_subnet(existing_mts):
    """
    Mount Targetが未設定のサブネットを検索
    """
    # 使用中のサブネット
    used_subnets = {mt['subnet_id'] for mt in existing_mts}
    
    # VPC内のすべてのサブネット
    vpc_id = os.environ['VPC_ID']
    ec2 = boto3.client('ec2')
    response = ec2.describe_subnets(
        Filters=[{'Name': 'vpc-id', 'Values': [vpc_id]}]
    )
    
    # 未使用のサブネットを返す
    for subnet in response['Subnets']:
        if subnet['SubnetId'] not in used_subnets:
            return subnet
    
    return None

def create_mount_target(fs_id, subnet_id):
    """
    新規Mount Target作成
    """
    sg_id = os.environ['EFS_SECURITY_GROUP_ID']
    
    # 作成
    response = efs.create_mount_target(
        FileSystemId=fs_id,
        SubnetId=subnet_id,
        SecurityGroups=[sg_id]
    )
    
    mt_id = response['MountTargetId']
    print(f"Mount Target作成済み: {mt_id}")
    
    # 作成完了を待機（最大5分）
    waiter = efs.get_waiter('mount_target_available')
    waiter.wait(
        MountTargetId=mt_id,
        WaiterConfig={'Delay': 10, 'MaxAttempts': 30}
    )
    
    # 最新情報を取得
    mt_info = efs.describe_mount_targets(MountTargetId=mt_id)
    mt = mt_info['MountTargets'][0]
    
    return {
        'mount_target_id': mt['MountTargetId'],
        'ip_address': mt['IpAddress'],
        'availability_zone': mt['AvailabilityZoneName'],
        'subnet_id': mt['SubnetId']
    }

def update_ssm_parameter(param_name, mount_targets):
    """
    SSM Parameter Store更新
    """
    import json
    from datetime import datetime
    
    value = json.dumps({
        'mount_targets': mount_targets,
        'updated_at': datetime.now().isoformat()
    })
    
    ssm.put_parameter(
        Name=param_name,
        Value=value,
        Type='String',
        Overwrite=True
    )
    
    print(f"SSMパラメータ更新済み: {param_name}")

def trigger_ecs_deployment(cluster, service):
    """
    ECSサービスのローリング更新を強制実行
    """
    ecs.update_service(
        cluster=cluster,
        service=service,
        forceNewDeployment=True
    )
    
    print(f"ECSデプロイ開始: {cluster}/{service}")
2. Fargateアプリケーション：ハッシュルーティング
pythonimport boto3
import hashlib
import os
import json
import subprocess

ssm = boto3.client('ssm')

class EFSLoadBalancer:
    """
    複数Mount Targetのロードバランサー管理
    """
    def __init__(self):
        self.mount_targets = []
        self.mount_points = []
        
    def initialize(self):
        """
        起動時初期化：SSMから設定取得 + NFSマウント
        """
        # 1. SSMからMount Target情報を取得
        param_name = os.environ['SSM_PARAMETER_NAME']
        response = ssm.get_parameter(Name=param_name)
        config = json.loads(response['Parameter']['Value'])
        
        self.mount_targets = config['mount_targets']
        print(f"SSMから{len(self.mount_targets)}個のMount Targetをロード")
        
        # 2. 各Mount Targetをマウント
        for idx, mt in enumerate(self.mount_targets):
            mount_point = f"/mnt/efs-{idx}"
            success = self._mount_nfs(mt, mount_point)
            
            if success:
                self.mount_points.append(mount_point)
                print(f"✅ マウント済み: {mt['ip_address']} → {mount_point}")
            else:
                print(f"❌ マウント失敗: {mt['ip_address']}")
        
        if len(self.mount_points) == 0:
            raise RuntimeError("すべてのMount Targetマウントが失敗")
        
        print(f"マウント成功 {len(self.mount_points)}/{len(self.mount_targets)}")
        
    def _mount_nfs(self, mount_target, mount_point):
        """
        NFSマウント実行
        """
        try:
            # マウントポイント作成
            os.makedirs(mount_point, exist_ok=True)
            
            # NFSマウント（TLS有効化）
            fs_id = os.environ['EFS_FILE_SYSTEM_ID']
            cmd = [
                'mount',
                '-t', 'efs',
                '-o', f'tls,iam,addr={mount_target["ip_address"]}',
                f'{fs_id}:/',
                mount_point
            ]
            
            subprocess.run(cmd, check=True, capture_output=True)
            return True
            
        except subprocess.CalledProcessError as e:
            print(f"マウント失敗: {e.stderr.decode()}")
            return False
    
    def get_file_path(self, original_path):
        """
        ハッシュルーティング：同一ディレクトリのファイルを異なるマウントポイントに分散
        
        ポイント：アプリケーションは常に同一パス(/data/analysis/file.json)を使用
        内部的に異なるMount Point (/mnt/efs-0, /mnt/efs-1, ...)にルーティング
        """
        # 1. ファイルパス全体をハッシュ化
        hash_value = hashlib.sha256(original_path.encode('utf-8')).hexdigest()
        hash_int = int(hash_value, 16)
        
        # 2. モジュロ演算でインデックス取得
        index = hash_int % len(self.mount_points)
        
        # 3. 選択されたマウントポイントでパス構築
        mount_point = self.mount_points[index]
        complete_path = os.path.join(mount_point, original_path)
        
        # 例：
        # original_path = "data/analysis/device-12345-20240115.json"
        # hash_int % 3 = 1
        # complete_path = "/mnt/efs-1/data/analysis/device-12345-20240115.json"
        
        return complete_path
    
    def read_file(self, path):
        """
        ファイル読み取り
        
        使用例：
        content = efs_lb.read_file('data/analysis/device-12345.json')
        ↓ 内部的にルーティング
        /mnt/efs-1/data/analysis/device-12345.json
        """
        actual_path = self.get_file_path(path)
        with open(actual_path, 'r', encoding='utf-8') as f:
            return f.read()
    
    def write_file(self, path, content):
        """
        ファイル書き込み
        
        ポイント：同一ファイルパスは常に同一Mount Pointにルーティング
        → 存在チェックと書き込みの整合性を保証
        """
        actual_path = self.get_file_path(path)
        
        # ディレクトリが存在しない場合は作成
        os.makedirs(os.path.dirname(actual_path), exist_ok=True)
        
        with open(actual_path, 'w', encoding='utf-8') as f:
            f.write(content)
    
    def file_exists(self, path):
        """
        ファイル存在チェック - この操作が大幅に高速化！
        
        従来：
        - /data/analysis/ に15万ファイル
        - os.path.exists() がすべてのエントリをスキャン → 30秒
        
        改善後：
        - 対応するMount Pointの /data/analysis/ には5万ファイルのみ
        - スキャン対象が1/3に削減 → < 1秒
        """
        actual_path = self.get_file_path(path)
        return os.path.exists(actual_path)
    
    def delete_file(self, path):
        """
        ファイル削除
        """
        actual_path = self.get_file_path(path)
        if os.path.exists(actual_path):
            os.remove(actual_path)

# グローバルインスタンス
efs_lb = EFSLoadBalancer()

def main():
    """
    アプリケーションエントリーポイント
    """
    # 初期化
    efs_lb.initialize()
    
    # 使用例：分析処理の典型的なフロー
    device_id = "12345"
    timestamp = "20240115-120000"
    file_path = f"data/analysis/device-{device_id}-{timestamp}.json"
    
    # 1. ファイル存在チェック（重複処理回避）
    # ← ここが30秒から < 1秒に短縮！
    if efs_lb.file_exists(file_path):
        print("処理済み")
        return
    
    # 2. 分析実行
    analysis_result = perform_analysis(device_id, timestamp)
    
    # 3. 結果保存
    efs_lb.write_file(file_path, json.dumps(analysis_result))
    
    print(f"処理・保存完了: {file_path}")

if __name__ == '__main__':
    main()
