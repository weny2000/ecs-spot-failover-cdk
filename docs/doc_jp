# → ハッシュ後にMount Target 2にルーティング
# → FileNotFoundError 🔥
解決策：マイグレーション処理
pythondef migrate_existing_files():
    """
    既存ファイルを新しいハッシュルールに従って再配置
    """
    # 1. Mount Target 1（旧ロケーション）からすべてのファイルを取得
    old_mount = '/mnt/efs-0/data/analysis/'
    
    for root, dirs, files in os.walk(old_mount):
        for filename in files:
            old_path = os.path.join(root, filename)
            
            # 相対パス
            relative_path = os.path.relpath(old_path, '/mnt/efs-0/')
            
            # 新しいハッシュで目的地を計算
            new_path = efs_lb.get_file_path(relative_path)
            
            # 既に正しい位置にあればスキップ
            if old_path == new_path:
                continue
            
            # ファイル移動
            os.makedirs(os.path.dirname(new_path), exist_ok=True)
            shutil.move(old_path, new_path)
            
            print(f"移行: {old_path} → {new_path}")

# デプロイ時に1回実行
migrate_existing_files()
本番環境での対処：
python# フォールバック付き読み取り
def read_file_with_fallback(self, path):
    """
    ハッシュ位置で見つからない場合、全Mount Pointを検索
    """
    # 1. 通常のハッシュルーティング
    actual_path = self.get_file_path(path)
    if os.path.exists(actual_path):
        return open(actual_path, 'r').read()
    
    # 2. フォールバック：全Mount Pointを検索
    for mount_point in self.mount_points:
        fallback_path = os.path.join(mount_point, path)
        if os.path.exists(fallback_path):
            # 見つかったら正しい位置に移動
            os.makedirs(os.path.dirname(actual_path), exist_ok=True)
            shutil.move(fallback_path, actual_path)
            return open(actual_path, 'r').read()
    
    raise FileNotFoundError(f"ファイルが見つかりません: {path}")
これにより既存ファイルが徐々に自動移行されます。
