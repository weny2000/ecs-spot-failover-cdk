        <!-- Connection: Spot Success Monitor to Cleanup Orchestrator -->
        <mxCell id="conn-monitor-cleanup" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#D05C17;fontSize=10;dashed=1;label=Invoke;labelPosition=center;verticalLabelPosition=top;align=center;verticalAlign=bottom;" edge="1" parent="1" source="spot-success-monitor" target="cleanup-orchestrator">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        
        <!-- Connection: Cleanup Orchestrator to Fargate Spot -->
        <mxCell id="conn-cleanup-spot" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#009900;fontSize=10;exitX=0.5;exitY=0;exitDx=0;exitDy=0;exitPerimeter=0;label=Start;labelPosition=right;verticalLabelPosition=middle;align=left;verticalAlign=middle;" edge="1" parent="1" source="cleanup-orchestrator" target="fargate-spot-service">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        
        <!-- Connection: Cleanup Orchestrator to Fargate Standard (Stop) -->
        <mxCell id="conn-cleanup-std" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#cc0000;fontSize=10;dashed=1;exitX=0.5;exitY=0;exitDx=0;exitDy=0;exitPerimeter=0;label=Stop;labelPosition=left;verticalLabelPosition=middle;align=right;verticalAlign=middle;" edge="1" parent="1" source="cleanup-orchestrator" target="fargate-standard-service">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        
        <!-- Connection: Lambda to SNS -->
        <mxCell id="conn-lambda-sns" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#FF4F8B;fontSize=10;exitX=1;exitY=0.5;exitDx=0;exitDy=0;exitPerimeter=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;entryPerimeter=0;" edge="1" parent="1" source="failback-orchestrator" target="sns">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        
        <!-- Connection: Lambda to CloudWatch Logs -->
        <mxCell id="conn-lambda-cw" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#E7157B;fontSize=10;dashed=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;exitPerimeter=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;entryPerimeter=0;" edge="1" parent="1" source="spot-error-detector" target="cloudwatch">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1130" y="860" />
            </Array>
          </mxGeometry>
        </mxCell>
        
      </root>
    </mxGraphModel>
  </diagram>
